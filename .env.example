# ── Anthropic (Claude agents via TokenRouter) ────────────────────────────────
# When routing through TokenRouter, the model id needs its provider prefix —
# run `curl https://api.tokenrouter.com/v1/models -H "x-api-key: $KEY"` to see
# which "anthropic/claude-..." ids your key's channel actually has available.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.tokenrouter.com/v1
ANTHROPIC_MODEL=anthropic/claude-sonnet-4

# ── Deepgram (speech-to-text) ────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Redis (patient history + vector memory) ──────────────────────────────────
# Preferred for application runtimes:
REDIS_URL=redis://localhost:6379

# Or use Redis Cloud management credentials to discover an Essentials database.
# The optional IDs avoid an account-wide discovery call on cold start.
REDIS_CLOUD_ACCOUNT_KEY=your-redis-cloud-account-key
REDIS_CLOUD_SECRET_KEY=your-redis-cloud-secret-key
REDIS_CLOUD_SUBSCRIPTION_ID=
REDIS_CLOUD_DATABASE_ID=

# ── Firebase (Google OAuth + Firestore drafts only — NOT patient history) ────
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-side Firebase Admin (JSON string or path — use JSON for Vercel)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

# ── Arize (agent observability / eval) ───────────────────────────────────────
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_MODEL_ID=cortex-agents
ARIZE_MODEL_VERSION=0.1.0
# Keep clinical prompt/output content out of telemetry unless explicitly approved.
ARIZE_CAPTURE_CONTENT=false
# Optional — same value as ARIZE_SPACE_ID; used by ax CLI and arize-skills
ARIZE_SPACE=your-arize-space-id

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Auth token (sntrys_...) enables sourcemap upload at build time via next.config.ts.
# DSN enables runtime error reporting; OTLP endpoint receives agent traces from
# OpenTelemetry (see sentry-otlp.ts). Public key for OTLP auth is in the DSN.
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=cortex
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123.ingest.us.sentry.io/456
SENTRY_DSN=https://your-key@o123.ingest.us.sentry.io/456
SENTRY_OTLP_ENDPOINT=https://o123.ingest.us.sentry.io/api/456/integration/otlp

# ── Embeddings (Redis vector search + normative RAG) ─────────────────────────
# hash = offline demo fallback; voyage or openai for real embeddings
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=voyage-3-lite
EMBEDDING_DIMS=64
VOYAGE_API_KEY=your-voyage-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Band (remote agents on app.band.ai) ───────────────────────────────────────
# Create five External Agents on Band (Connect Remote Agent), copy UUID + band_a_* key each.
# Cortex creates rooms via Wernicke's key; workers connect with their own per-agent keys.
BAND_SYNC_SECRET=your-band-sync-secret
BAND_AGENT_HANDLE_PREFIX=your-band-handle-prefix
BAND_WERNICKE_AGENT_ID=your-wernicke-agent-uuid
BAND_WERNICKE_API_KEY=band_a_your-wernicke-key
BAND_NORM_AGENT_ID=your-norm-agent-uuid
BAND_NORM_API_KEY=band_a_your-norm-key
BAND_ENGRAM_AGENT_ID=your-engram-agent-uuid
BAND_ENGRAM_API_KEY=band_a_your-engram-key
BAND_BROCA_AGENT_ID=your-broca-agent-uuid
BAND_BROCA_API_KEY=band_a_your-broca-key
BAND_GLIA_AGENT_ID=your-glia-agent-uuid
BAND_GLIA_API_KEY=band_a_your-glia-key
# Optional legacy fallback if all agents share one key:
# BAND_API_KEY=your-band-api-key
THENVOI_REST_URL=https://app.band.ai/api/v1/agent
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ── Terac (human annotation marketplace, terac.com) ───────────────────────────
# API key + project come from your Terac org settings; review secret is any
# random string you generate — it signs the opaque /annotate/[token] links.
TERAC_API_KEY=your-terac-api-key
TERAC_PROJECT_ID=your-terac-project-id
TERAC_REVIEW_SECRET=your-terac-review-secret
TERAC_BASE_URL=https://terac.com/api/external/v2
# TERAC_APP_BASE_URL=https://your-deployed-cortex-url.com

# ── Glia eval (Arize before/after demo) ──────────────────────────────────────
GLIA_ENABLED=true
EVAL_VARIANT=glia-on

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Keep false in production except for a temporary hackathon judging deployment.
ALLOW_DEMO_AUTH=false

# Credentials are optional during local development. /api/health reports which
# integrations are configured; missing integrations use development fallbacks.
