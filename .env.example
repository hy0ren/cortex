# ── Anthropic (Claude agents via TokenRouter) ────────────────────────────────
# When routing through TokenRouter, the model id needs its provider prefix —
# run `curl https://api.tokenrouter.com/v1/models -H "x-api-key: $KEY"` to see
# which "anthropic/claude-..." ids your key's channel actually has available.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.tokenrouter.com/v1
ANTHROPIC_MODEL=anthropic/claude-sonnet-4

# ── Deepgram (speech-to-text) ────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Redis (patient history + vector memory) ──────────────────────────────────
# Preferred for application runtimes:
REDIS_URL=redis://localhost:6379

# Or use Redis Cloud management credentials to discover an Essentials database.
# The optional IDs avoid an account-wide discovery call on cold start.
REDIS_CLOUD_ACCOUNT_KEY=your-redis-cloud-account-key
REDIS_CLOUD_SECRET_KEY=your-redis-cloud-secret-key
REDIS_CLOUD_SUBSCRIPTION_ID=
REDIS_CLOUD_DATABASE_ID=

# ── Firebase (Google OAuth + Firestore drafts only — NOT patient history) ────
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-side Firebase Admin (JSON string or path — use JSON for Vercel)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

# ── Arize (agent observability / eval) ───────────────────────────────────────
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_MODEL_ID=cortex-agents
ARIZE_MODEL_VERSION=0.1.0
# Keep clinical prompt/output content out of telemetry unless explicitly approved.
ARIZE_CAPTURE_CONTENT=false
# Optional — same value as ARIZE_SPACE_ID; used by ax CLI and arize-skills
ARIZE_SPACE=your-arize-space-id

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Auth token (sntrys_...) enables sourcemap upload at build time via next.config.ts.
# DSN enables runtime error reporting; OTLP endpoint receives agent traces from
# OpenTelemetry (see sentry-otlp.ts). Public key for OTLP auth is in the DSN.
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=cortex
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123.ingest.us.sentry.io/456
SENTRY_DSN=https://your-key@o123.ingest.us.sentry.io/456
SENTRY_OTLP_ENDPOINT=https://o123.ingest.us.sentry.io/api/456/integration/otlp

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Keep false in production except for a temporary hackathon judging deployment.
ALLOW_DEMO_AUTH=false

# Credentials are optional during local development. /api/health reports which
# integrations are configured; missing integrations use development fallbacks.
